{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "RabbitMQ": {

    "HostName": "localhost",

    "Port": 5672,

    "VirtualHost": "/",

    "UserName": "guest",

    "Password": "guest",

    "ClientProvidedName": "InvestmentPortfolio.Api",

    "AutomaticRecoveryEnabled": true,

    "NetworkRecoveryInterval": "00:00:10",

    "RequestedHeartbeat": "00:00:30",

    "UseSsl": false,

    "ExchangeName": "investment.exchange",

    "ExchangeType": "topic",

    "DurableExchange": true,

    "PrefetchCount": 20,

    "PublishRetryCount": 5,

    "PublishTimeout": "00:00:30",

    "MessageExpiration": "7.00:00:00",

    "PublisherConfirms": true,

    "PublisherReturns": true,

    "DeadLetterExchange": "investment.dlx",

    "DeadLetterQueue": "investment.dlq",

    "OutboxExchange": "investment.outbox",

    "OutboxQueue": "investment.outbox.queue"
  },
  "status": "Healthy",
  "entries": {
    "rabbitmq": {
      "status": "Healthy",
      "description": "RabbitMQ disponível",
      "data": {
        "host": "localhost",
        "port": 5672,
        "connected": true,
        "checkedAt": "2026-07-14T..."
      }
    }

  },
  "ConnectionStrings": { "DefaultConnection": "Host=localhost;Port=5432;Database=InvestYes;Username=postgres;Password=postgres" },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],

    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },

    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],

    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithProcessId"
    ],

    "Properties": {
      "Application": "InvestYes.API"
    }
  },
  "OpenTelemetry": {
    "ServiceName": "InvestYes.API",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "http://localhost:4317"
  },
  "MarketData": {
    "Provider": "Yahoo",

    "YahooFinance": {
      "BaseUrl": "https://query1.finance.yahoo.com/"
    },

    "Brapi": {
      "BaseUrl": "https://brapi.dev/api/",
      "Token": "AQUI_UM_TOKEN_BRAPI"
    },

    "FundsExplorer": {
      "BaseUrl": "https://www.fundsexplorer.com.br/funds/"
    }
  },
  "Jwt": {
    "Issuer": "InvestYes",
    "Audience": "InvestYes.Api",
    "SecretKey": "AQUI_UMA_CHAVE_DE_64_CARACTERES_BEM_GRANDE_E_SECRETA",
    "ExpirationMinutes": 120
  }
}
